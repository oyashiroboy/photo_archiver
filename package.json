{
  "name": "photo-archiver",
  "private": true,
  "scripts": {
    "build:gallery": "node scripts/build-gallery.mjs",
    "prepare:wrangler": "node scripts/prepare-wrangler-config.mjs",
    "dev:gallery": "npm run prepare:wrangler && wrangler dev --config .wrangler.generated.toml",
    "deploy:gallery": "npm run prepare:wrangler && wrangler deploy --config .wrangler.generated.toml",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "archiver": "^7.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "wrangler": "^4.71.0"
  }
}
